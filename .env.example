APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Produção: APP_ENV=production, APP_DEBUG=false, HTTPS na URL pública.

# Origens permitidas pelo CORS para o React em desenvolvimento (Vite). Separe várias com vírgula.
CORS_ALLOWED_ORIGINS=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=conta_certa
DB_USERNAME=root
DB_PASSWORD=

# Docker: senha de root já fixada na 1ª criação do volume. Se falhar ao rodar scripts/mysql-ensure-database.sh
# ou ao abrir PhpMyAdmin, defina a senha real de root (pode diferir do DB_USERNAME do app):
# MYSQL_ROOT_PASSWORD=

# Docker Compose neste repositório: use DB_HOST=db e DB_PORT=3306. O serviço `db` cria
# MYSQL_DATABASE a partir de DB_DATABASE. Usuário app padrão do compose: DB_USERNAME=username,
# DB_PASSWORD=userpass (ou defina DB_PASSWORD no .env — também alimenta MYSQL_ROOT_PASSWORD).

# SQLite não é mais o padrão. Testes PHPUnit continuam com sqlite :memory: (phpunit.xml).
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_TOKEN_EXPIRATION_MINUTES=43200

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_TIMEOUT=10
